# LiteLLM Configuration
LITELLM_MASTER_KEY=sk-test-1234567890
LITELLM_SALT_KEY=sk-salt-1234567890
LITELLM_PORT=8000

# AWS Bedrock credentials
# For local testing: Use fake credentials (LiteLLM mock_response: true)
# For production: Replace with real AWS IAM credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ca-central-1

# OpenCode Server Configuration
OPENCODE_SERVER_PASSWORD=local-test-password-123
OPENCODE_PORT=4096

# OpenCode Web UI Configuration
OPENCODE_WEB_PORT=3001

# Nginx Configuration
NGINX_PORT=8080
NGINX_SSL_PORT=8443

# LiteLLM API Endpoint (for OpenCode to connect)
# Note: Use internal container port 4000, not host port 8000
LITELLM_API_BASE=http://litellm:4000

# User Configuration (auto-detected by manage.sh)
# These are automatically set from your host user for proper file permissions
# USER_UID=501
# USER_GID=20
# Note: UID/GID matching ensures files created in container have correct ownership on host
